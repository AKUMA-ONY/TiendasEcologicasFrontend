---
import '../../styles/navbar.css';

const navLinks = [
  { label: "Inicio",    href: "/" },
  { label: "Catálogo",  href: "/catalogo" },
  { label: "Nosotros",  href: "/nosotros" },
  { label: "Contacto",  href: "/contacto" },
  { label: "Servicios", href: "/servicios" },
];
---

<header class="navbar">
  <div class="navbar__inner">

    <!-- Logo -->
    <a href="/" class="navbar__brand" aria-label="Brisx inicio">
      <span class="navbar__logo-icon">B</span>
      <span class="navbar__logo-text">Bris<em>x</em></span>
    </a>

    <!-- Links -->
    <nav class="navbar__nav" id="main-nav" aria-label="Navegación principal">
      <ul class="navbar__list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="navbar__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Burger (móvil) -->
    <button
      class="navbar__burger"
      id="burger-btn"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="main-nav"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<script>
  const burger = document.getElementById('burger-btn') as HTMLButtonElement;
  const nav    = document.getElementById('main-nav') as HTMLElement;

  burger.addEventListener('click', () => {
    const isOpen = nav.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
  });
</script>
